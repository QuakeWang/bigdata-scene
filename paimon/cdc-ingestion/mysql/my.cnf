[mysqld]
# ========================================
# CDC required: enable binlog
# ========================================
server-id         = 1
log_bin           = mysql-bin
binlog_format     = ROW
binlog_row_image  = FULL
expire_logs_days  = 3

# ========================================
# Character set
# ========================================
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# ========================================
# Performance (lightweight for Docker)
# ========================================
max_connections       = 100
innodb_buffer_pool_size = 256M
